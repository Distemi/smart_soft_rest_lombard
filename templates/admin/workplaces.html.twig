{% extends 'base.html.twig' %}

{% block title %}Филиалы - Админ-панель{% endblock %}

{% block navbar %}
{{ include('components/_admin_navbar.html.twig') }}
{% endblock %}

{% block body %}
<div class="container-fluid my-4">
    <h1 class="mb-4">Филиалы</h1>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Название</th>
                            <th>Адрес</th>
                            <th>Телефон</th>
                            <th>Клиенты</th>
                            <th>Билеты</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for workplace in workplaces %}
                        <tr>
                            <td>{{ workplace.id }}</td>
                            <td>
                                <strong>{{ workplace.displayTitle }}</strong>
                                <div class="text-muted small">внешний id: {{ workplace.externalId }}</div>
                            </td>
                            <td>{{ workplace.address ?? '-' }}</td>
                            <td>{{ workplace.phone|format_phone }}</td>
                            <td><span class="badge bg-primary">{{ clientsStats[workplace.id] ?? 0 }}</span></td>
                            <td><span class="badge bg-secondary">{{ workplace.pawnTickets|length }}</span></td>
                            <td>
                                {% if workplace.isActive %}
                                    <span class="badge bg-success">Активен</span>
                                {% else %}
                                    <span class="badge bg-danger">Неактивен</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_admin_workplace_view', {id: workplace.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Просмотр
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center">Филиалы не найдены</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
