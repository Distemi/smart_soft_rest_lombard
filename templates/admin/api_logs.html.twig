{% extends 'base.html.twig' %}

{% block title %}API Логи - Админ-панель{% endblock %}

{% block navbar %}
{{ include('components/_admin_navbar.html.twig') }}
{% endblock %}

{% block body %}
<div class="container-fluid my-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h1 class="mb-0">Логи обращений к API</h1>
        <small class="text-muted">
            Всего: {{ totalLogs }} | Страница {{ page }} из {{ totalPages }}
        </small>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Дата/Время</th>
                            <th>Endpoint</th>
                            <th>Параметры</th>
                            <th>Результат</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                        <tr>
                            <td>{{ log.id }}</td>
                            <td>{{ log.createdAt|date('d.m.Y H:i:s') }}</td>
                            <td><code>{{ log.endpoint }}</code></td>
                            <td><small class="text-muted">{{ log.requestSummary ?? '-' }}</small></td>
                            <td><small>{{ log.responseSummary ?? '-' }}</small></td>
                            <td>
                                {% if log.statusCode >= 200 and log.statusCode < 300 %}
                                    <span class="badge bg-success">{{ log.statusCode }}</span>
                                {% elseif log.statusCode >= 400 %}
                                    <span class="badge bg-danger">{{ log.statusCode }}</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ log.statusCode }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center">Логи отсутствуют</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {% if totalPages > 1 %}
        <nav class="mt-3" aria-label="Пагинация логов API">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {% if page <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_admin_api_logs', {'page': page - 1}) }}" aria-label="Предыдущая">
                        &laquo;
                    </a>
                </li>

                {% set startPage = max(1, page - 2) %}
                {% set endPage = min(totalPages, page + 2) %}

                {% for p in startPage..endPage %}
                    <li class="page-item {% if p == page %}active{% endif %}">
                        <a class="page-link" href="{{ path('app_admin_api_logs', {'page': p}) }}">{{ p }}</a>
                    </li>
                {% endfor %}

                <li class="page-item {% if page >= totalPages %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_admin_api_logs', {'page': page + 1}) }}" aria-label="Следующая">
                        &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
