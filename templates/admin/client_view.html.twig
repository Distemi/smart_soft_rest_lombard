{% extends 'base.html.twig' %}

{% block title %}Клиент "{{ client.fullName }}" - Админ-панель{% endblock %}

{% block navbar %}
{{ include('components/_admin_navbar.html.twig') }}
{% endblock %}

{% block body %}
<div class="container-fluid my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_clients') }}">Клиенты</a></li>
            <li class="breadcrumb-item active">{{ client.fullName }}</li>
        </ol>
    </nav>

    <h1 class="mb-4">Клиент: {{ client.fullName }}</h1>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Личная информация</h5>
                </div>
                <div class="card-body">
                    <p><strong>ID:</strong> {{ client.id }}</p>
                    <p><strong>Внешний ID:</strong> {{ client.externalId }}</p>
                    <p><strong>ФИО:</strong> {{ client.fullName }}</p>
                    <p><strong>Телефон:</strong> {{ client.phone|format_phone }}</p>
                    <p><strong>Email:</strong> {{ client.email ?? '-' }}</p>
                    {% if client.passportSeries or client.passportNumber %}
                        <p><strong>Паспорт:</strong> {{ client.passportSeries }} {{ client.passportNumber }}</p>
                    {% endif %}
                    <p><strong>Дата создания:</strong> {{ client.createdAt|date('d.m.Y H:i') }}</p>
                    <p><strong>Дата обновления:</strong> {{ client.updatedAt|date('d.m.Y H:i') }}</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Залоговые билеты ({{ client.pawnTickets|length }})</h5>
                </div>
                <div class="card-body">
                    {% if client.pawnTickets|length > 0 %}
                        <div class="list-group">
                            {% for ticket in client.pawnTickets %}
                                <a href="{{ path('app_admin_ticket_view', {workplaceId: ticket.workplace.id, ticketNumber: ticket.ticketNumber}) }}" 
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">{{ ticket.ticketNumber }}</h6>
                                        {% if ticket.isOpen %}
                                            <span class="badge bg-success">{{ ticket.statusLabel }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ ticket.statusLabel }}</span>
                                        {% endif %}
                                    </div>
                                    <p class="mb-1">Сумма: {{ ticket.loanAmount|number_format(2, '.', ' ') }} ₽</p>
                                    <small>{{ ticket.issueDate|date('d.m.Y') }}</small>
                                </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted">Залоговые билеты отсутствуют</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <a href="{{ path('app_admin_clients') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад к списку
    </a>
</div>
{% endblock %}
