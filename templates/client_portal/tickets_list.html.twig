{% extends 'base.html.twig' %}

{% block title %}Мои залоговые билеты - Личный кабинет{% endblock %}

{% block navbar %}
{{ include('components/_client_navbar.html.twig') }}
{% endblock %}

{% block body %}
<div class="container my-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Мои открытые залоговые билеты</h1>

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}

            {% if tickets|length == 0 %}
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> У вас нет открытых залоговых билетов
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Номер билета</th>
                                <th>Дата выдачи</th>
                                <th>Дата возврата</th>
                                <th>Сумма займа</th>
                                <th>Текущий долг</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for ticket in tickets %}
                            <tr>
                                <td><strong>{{ ticket.ticketNumber }}</strong></td>
                                <td>{{ ticket.issueDate|date('d.m.Y') }}</td>
                                <td>{{ ticket.dueDate|date('d.m.Y') }}</td>
                                <td>{{ ticket.loanAmount|number_format(2, '.', ' ') }} ₽</td>
                                <td>{{ ticket.currentDebt|number_format(2, '.', ' ') }} ₽</td>
                                <td>
                                    {% if ticket.isOpen %}
                                        <span class="badge bg-success">{{ ticket.statusLabel }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ ticket.statusLabel }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('app_ticket_view', {workplaceId: ticket.workplace.id, ticketNumber: ticket.ticketNumber}) }}" class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> Просмотр
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
